# Google Gemini API Key 設定
# 請將此檔案複製並重新命名為 .env，然後填入您的 API 金鑰。
# 您可以在此處申請免費 API Key: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# DIGITIMES 會員帳號密碼設定（可留空）
# 如果您有 DIGITIMES 付費會員，請填寫下方帳密。
# 程式會自動以會員身份登入，順利抓取付費文章的全文進行 AI 分析。
DIGITIMES_USER=your_digitimes_username_or_email
DIGITIMES_PASSWORD=your_digitimes_password

# Google Alerts RSS Feed 設定 (方案一：適用於國際經濟主題)
# 請將您在 Google 快訊所設定之「國際經濟」快訊的傳送對象改為「RSS 訂閱源」，並在此填入該 RSS URL。
# 例如：https://www.google.com.tw/alerts/feeds/12345678901234567890/12345678901234567890
GOOGLE_ALERT_RSS_ECON=

